# --- GERAL DO SISTEMA OPERACIONAL ---
.DS_Store
Thumbs.db
*.log

# --- PYTHON / DJANGO ---
__pycache__/
*.py[cod]
*$py.class

# Ambiente Virtual (onde estão as libs do python)
venv/
env/
.env

# Banco de Dados (SQLite local não deve subir para produção)
db.sqlite3
db.sqlite3-journal

# Arquivos de Mídia (Uploads dos usuários - Fotos, PDFs)
# Importante: Não queremos versionar fotos de pessoas reais
media/
media/uploads/
media/fotos_beneficiarios/
media/documentos/

# Arquivos Estáticos coletados (gerados pelo collectstatic)
static/
staticfiles/

# --- FRONTEND (VUE.JS / NODE) ---
# Dependências do Node (gigantes, nunca suba isso)
node_modules/
frontend/node_modules/

# Build de produção (pasta gerada pelo npm run build)
dist/
frontend/dist/

# Logs de erro do NPM
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- IDEs (Configurações do editor) ---
.vscode/
.idea/
*.swp
*.swo